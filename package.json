{
  "name": "sms-bulk-tz",
  "version": "1.0.1",
  "description": "A production-ready Node.js client for the TAPSA Bulk SMS API — send single or bulk SMS messages to Tanzanian phone numbers with retry, validation, and structured error handling.",
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "require": "./index.js"
    }
  },
  "scripts": {
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint index.js",
    "lint:fix": "eslint index.js --fix"
  },
  "keywords": [
    "sms",
    "bulk-sms",
    "tanzania",
    "tapsa",
    "sms-api",
    "messaging",
    "tz",
    "255"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Lazack28/sms-bulk-tz.git"
  },
  "bugs": {
    "url": "https://github.com/Lazack28/sms-bulk-tz/issues"
  },
  "homepage": "https://github.com/Lazack28/sms-bulk-tz#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "dependencies": {
    "axios": "^1.7.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "axios-mock-adapter": "^1.22.0"
  },
  "files": [
    "index.js",
    "index.d.ts",
    "README.md",
    "LICENSE"
  ],
  "jest": {
    "testEnvironment": "node",
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
